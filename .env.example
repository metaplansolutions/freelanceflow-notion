# FreelanceFlow — Environment Variables
# Copy this file to .env and fill in your values

# Get your Notion MCP OAuth token at: https://mcp.notion.com/mcp
# Click "Connect" and follow the OAuth flow — the token appears after authorization.
NOTION_MCP_TOKEN=your_notion_mcp_token_here

# The ID of your "Client Pipeline" Notion database.
# Find it in the database URL: https://www.notion.so/workspace/{DATABASE_ID}?v=...
# Or leave blank — the client will search your workspace automatically.
NOTION_DATABASE_ID=your_database_id_here
